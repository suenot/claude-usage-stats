	path = reference
	url = https://github.com/658jjh/claude-usage-tracker.git
[submodule "core"]
	path = core
	url = /tmp/claude-stats-init/core
[submodule "backend"]
	path = backend
	url = /tmp/claude-stats-init/backend
[submodule "frontend"]
	path = frontend
	url = /tmp/claude-stats-init/frontend
[submodule "cli"]
	path = cli
	url = /tmp/claude-stats-init/cli
